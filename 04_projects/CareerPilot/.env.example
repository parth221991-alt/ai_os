# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/careerpilot

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram (optional — for notifications) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Gmail ────────────────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console → APIs → Gmail API → OAuth2
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_PUBSUB_TOPIC=projects/your-project/topics/gmail-push   # optional, for push notifications

# ── LinkedIn ─────────────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your-linkedin-email@gmail.com
LINKEDIN_PASSWORD=your-linkedin-password

# ── Naukri ───────────────────────────────────────────────────────────────────
NAUKRI_EMAIL=your-naukri-email@gmail.com
NAUKRI_PASSWORD=your-naukri-password

# ── Indeed ───────────────────────────────────────────────────────────────────
INDEED_EMAIL=your-indeed-email@gmail.com
INDEED_PASSWORD=your-indeed-password
