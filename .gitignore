# Python environments
**/.venv/
**/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Node (nested projects manage their own node_modules via their own .gitignore)
**/node_modules/
**/.next/

# Env files and secrets — never commit
**/.env
**/.env.local
**/.env.*.local
**/.env.bak
**/credentials.json
**/service-account*.json
**/character_config.yaml

# Playwright sessions (contain auth cookies)
**/playwright-sessions/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
**/coverage/
